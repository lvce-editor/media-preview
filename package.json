{
  "name": "builtin.media-preview-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.js",
    "dev": "node ./packages/build/src/dev.js",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check .",
    "test": "lerna run test",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 130
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^16.4.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "lerna": "^8.2.3",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.0"
  }
}
